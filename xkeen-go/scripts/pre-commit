#!/bin/sh
# Pre-commit hook: run linters on staged files
# Blocks commit if linters fail. Bypass with: git commit --no-verify
#
# This hook is auto-installed by: xkeen-go/scripts/setup-hooks.sh
# Or manually: cp xkeen-go/scripts/pre-commit .git/hooks/pre-commit && chmod +x

set -e

echo "🔍 Running pre-commit checks..."

# --- Get staged files ---
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | grep -v '_test\.go$' || true)
STAGED_JS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|vue|ts)$' || true)
STAGED_GO_TEST=$(git diff --cached --name-only --diff-filter=ACM | grep '_test\.go$' || true)

# --- Go: golangci-lint (if available) ---
if [ -n "$STAGED_GO" ] || [ -n "$STAGED_GO_TEST" ]; then
    if command -v golangci-lint >/dev/null 2>&1; then
        echo "  → golangci-lint (Go files)"
        cd xkeen-go
        # Run on the whole package (golangci-lint needs compilation context)
        golangci-lint run ./... 2>&1 | sed 's/^/    /'
        cd ..
        echo "  ✓ golangci-lint passed"
    else
        echo "  ⚠ golangci-lint not installed — skipping Go lint"
        echo "    Install: https://golangci-lint.run/welcome/install/"
    fi
fi

# --- Frontend: eslint (if node_modules available) ---
if [ -n "$STAGED_JS" ]; then
    if [ -d "xkeen-go/web/node_modules" ]; then
        echo "  → eslint (JS/Vue files)"
        # Convert repo-root-relative paths to web-relative paths for eslint
        WEB_JS=""
        for f in $STAGED_JS; do
            # Strip xkeen-go/web/ prefix if present
            rel=$(echo "$f" | sed 's|^xkeen-go/web/||')
            # Only lint files inside web/
            case "$f" in
                xkeen-go/web/*) WEB_JS="$WEB_JS $rel" ;;
            esac
        done
        if [ -n "$WEB_JS" ]; then
            cd xkeen-go/web
            npx eslint $WEB_JS 2>&1 | sed 's/^/    /' || {
                echo "  ✗ eslint found issues — commit blocked"
                exit 1
            }
            echo "  ✓ eslint passed"
            cd ../../
        else
            echo "  → eslint: no web/ files staged, skipping"
        fi
    else
        echo "  ⚠ node_modules not found — skipping frontend lint"
        echo "    Install: cd xkeen-go/web && npm install"
    fi
fi

# --- Go: go vet (always, fast) ---
if [ -n "$STAGED_GO" ] || [ -n "$STAGED_GO_TEST" ]; then
    echo "  → go vet"
    cd xkeen-go
    if ! go vet ./... 2>&1 | sed 's/^/    /'; then
        echo "  ✗ go vet found issues — commit blocked"
        exit 1
    fi
    echo "  ✓ go vet passed"
    cd ..
fi

# --- Changelog check (mandatory for user-facing code) ---
# If user-facing source files changed, changelog.json must also be updated.
# Bypass: SKIP_CHANGELOG=1 git commit ...
if [ "$SKIP_CHANGELOG" != "1" ]; then
    # User-facing code = handlers, config, server, components, services, stores
    # Exclude test files and scripts
    USER_FACING=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'xkeen-go/(internal/(handlers|config|server|subscription)/.*\.go|web/src/(components|services|stores)/.*\.(js|vue))$' | grep -vE '_test\.go$|\.test\.js$' || true)
    CHANGELOG_CHANGED=$(git diff --cached --name-only | grep 'internal/version/changelog.json' || true)

    if [ -n "$USER_FACING" ] && [ -z "$CHANGELOG_CHANGED" ]; then
        echo ""
        echo "  ❌ Изменён пользовательский код, но changelog.json не обновлён."
        echo "     Добавьте запись в xkeen-go/internal/version/changelog.json (секция unreleased)"
        echo "     или обойдите: SKIP_CHANGELOG=1 git commit ..."
        echo ""
        exit 1
    fi

    # Validate changelog.json structure if changed
    if [ -n "$CHANGELOG_CHANGED" ] && command -v jq >/dev/null 2>&1; then
        if ! jq -e '
            (.unreleased | type == "array") and
            (.releases | type == "array") and
            (.unreleased[]? | (.type | IN("feat","fix","tweak")) and (.text | length > 0) and (.important | type == "boolean")) and
            (.releases[]? | has("version") and has("date") and has("changes")) and
            (.releases[]?.changes[]? | (.type | IN("feat","fix","tweak")) and (.text | length > 0) and (.important | type == "boolean"))
        ' xkeen-go/internal/version/changelog.json > /dev/null 2>&1; then
            echo "  ✗ changelog.json: invalid structure"
            echo "    Each entry needs: type (feat|fix|tweak), text (non-empty), important (bool)"
            exit 1
        fi
        echo "  ✓ changelog.json valid"
    fi
fi

echo "✅ All pre-commit checks passed!"
exit 0
