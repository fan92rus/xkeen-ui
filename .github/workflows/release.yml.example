# Example GitHub Actions workflow for releases with SHA256 checksums
# Add this to .github/workflows/release.yml

name: Release

on:
  push:
    tags:
      - 'v*.*.*'

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v5

      - name: Set up Go
        uses: actions/setup-go@v6
        with:
          go-version: '1.26'

      - name: Build for Keenetic ARM64
        run: |
          CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go build -ldflags "-s -w" -o xkeen-go-keenetic-arm64 .
          # Compress with UPX (optional, reduces size by ~70%)
          # sudo apt-get install -y upx-ucl
          # upx --best --lzma xkeen-go-keenetic-arm64

      - name: Generate SHA256 checksum
        run: |
          sha256sum xkeen-go-keenetic-arm64 > xkeen-go-keenetic-arm64.sha256
          echo "Checksum:"
          cat xkeen-go-keenetic-arm64.sha256

      - name: Create Release
        uses: softprops/action-gh-release@v3
        with:
          files: |
            xkeen-go-keenetic-arm64
            xkeen-go-keenetic-arm64.sha256
          generate_release_notes: true
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Verify release assets
        run: |
          echo "Release created with the following assets:"
          echo "- xkeen-go-keenetic-arm64 (binary)"
          echo "- xkeen-go-keenetic-arm64.sha256 (checksum)"
          echo ""
          echo "Users can verify the download with:"
          echo "  sha256sum -c xkeen-go-keenetic-arm64.sha256"
